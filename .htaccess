# Subida de archivos: límites suficientes para fotos de cámara de teléfono
# (cPanel suele limitar a 2-8 MB por defecto). Estos valores requieren que
# el plan de hosting permita override de estas directivas.
<IfModule mod_php.c>
    php_value upload_max_filesize 25M
    php_value post_max_size 30M
    php_value max_input_time 120
    php_value memory_limit 256M
</IfModule>
<IfModule mod_php7.c>
    php_value upload_max_filesize 25M
    php_value post_max_size 30M
    php_value max_input_time 120
    php_value memory_limit 256M
</IfModule>
<IfModule mod_php8.c>
    php_value upload_max_filesize 25M
    php_value post_max_size 30M
    php_value max_input_time 120
    php_value memory_limit 256M
</IfModule>

# ============================================================
# SEGURIDAD (endurecimiento pre-producción):
# Bloquea del acceso web TODOS los scripts de desarrollo / diagnóstico /
# migración / privilegio. NO deben ser alcanzables por URL en producción
# (varios vuelcan sesión, permisos o esquema, ejecutan DDL, o mutan roles).
# Verificado: ninguno está referenciado por el código real de la app.
# (Apache 2.4 — directiva Require). Reversible: elimina estos bloques.
#   Peligrosos confirmados por la auditoría:
#   - run_*/migrate_*: ejecutan DDL/DML al cargar la URL
#   - fix_session / fix_developer_role / make_codes_universal / install_*: mutan/elevan sesión, roles o ajustes
#   - debug_auth_code: vuelca códigos de autorización sin auth (+XSS)
#   - debug_*/check_*/validate_*: vuelcan sesión / permisos / esquema DB
#   - *_test / test_*: andamiaje de pruebas (p.ej. campaign_staffing_test con permiso desactivado)
# ============================================================
<FilesMatch "^(debug_|tmp_|setup_|migrate_|run_|fix_|make_|install_|check_|verify_|validate_|analyze_|simulate_|recalculate_|test_).*\.php$">
    Require all denied
</FilesMatch>
<FilesMatch "(_test\.php$|^ghl_api_examples\.php$|^configure_test_email\.php$|^punch_qa\.php$|^secrets\.php$|^secrets\.example\.php$)">
    Require all denied
</FilesMatch>

# Habilitar el motor de reescritura
RewriteEngine On

# Eliminar .php de las URLs
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*)$ $1.php [L]

# Redirigir URLs con .php a URLs sin .php (excepto APIs que necesitan POST)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteCond %{REQUEST_URI} !^/api/
RewriteCond %{REQUEST_URI} !^/ponche-xtreme/api/
RewriteCond %{REQUEST_URI} !^/chat/
RewriteCond %{REQUEST_URI} !^/ponche-xtreme/chat/
RewriteCond %{REQUEST_URI} !^/hr/
RewriteCond %{REQUEST_URI} !^/ponche-xtreme/hr/
RewriteCond %{REQUEST_URI} !^/submit_application\.php$
RewriteCond %{REQUEST_URI} !^/ponche-xtreme/submit_application\.php$
RewriteCond %{REQUEST_URI} !supervisor_.*_api\.php$
RewriteCond %{REQUEST_URI} !_api\.php$
RewriteCond %{REQUEST_URI} !delete_record\.php$
RewriteCond %{REQUEST_URI} !edit_record\.php$
RewriteCond %{REQUEST_URI} !create_manual_punch\.php$
RewriteCond %{REQUEST_URI} !save_schedule_template\.php$
RewriteCond %{REQUEST_URI} !update_schedule_template\.php$
RewriteCond %{REQUEST_URI} !delete_schedule_template\.php$
RewriteCond %{REQUEST_URI} !get_schedule_template\.php$
RewriteRule ^ %1 [R=301,L]
